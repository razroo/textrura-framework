{
  "name": "textura",
  "version": "1.19.12",
  "description": "DOM-free layout engine combining Yoga flexbox with Pretext text measurement",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/razroo/geometra",
    "directory": "packages/textura"
  },
  "homepage": "https://razroo.github.io/geometra",
  "keywords": [
    "layout",
    "flexbox",
    "yoga",
    "dom-free",
    "canvas",
    "text-measurement"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "test": "vitest run --root ../.. --config vitest.fast.config.ts packages/textura/src/__tests__/compute-layout.test.ts",
    "demo:dev": "vite --config demo/vite.config.ts",
    "demo:build": "vite build --config demo/vite.config.ts"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.3",
    "yoga-layout": "^3.2.1"
  }
}
