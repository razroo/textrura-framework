{
  "name": "@geometra/renderer-three",
  "version": "1.55.0",
  "description": "Three.js render target helpers for Geometra — stack WebGL with the geometry-streamed canvas client, declarative scene3d element rendering",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/razroo/geometra",
    "directory": "packages/renderer-three"
  },
  "homepage": "https://razroo.github.io/geometra",
  "keywords": [
    "geometra",
    "three",
    "three.js",
    "webgl",
    "renderer",
    "dom-free",
    "websocket",
    "scene3d"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@geometra/client": "^1.6.0",
    "@geometra/core": "^1.6.0",
    "@geometra/renderer-canvas": "^1.6.0"
  },
  "peerDependencies": {
    "three": ">=0.160.0 <0.180.0"
  },
  "devDependencies": {
    "@types/three": "^0.170.0",
    "three": "^0.170.0"
  }
}
