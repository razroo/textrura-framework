{
  "name": "@geometra/cli",
  "version": "1.61.1",
  "description": "CLI to view any Geometra-powered site in the terminal",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/razroo/geometra",
    "directory": "packages/cli"
  },
  "homepage": "https://razroo.github.io/geometra",
  "keywords": [
    "geometra",
    "cli",
    "terminal",
    "tui"
  ],
  "bin": {
    "geometra": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@geometra/core": "^1.12.0",
    "@geometra/renderer-terminal": "^1.12.0",
    "textura": "^1.11.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0"
  }
}
