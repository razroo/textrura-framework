{
  "name": "@geometra/server",
  "version": "1.25.0",
  "description": "Server-side layout engine with WebSocket geometry streaming",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/razroo/geometra",
    "directory": "packages/server"
  },
  "homepage": "https://razroo.github.io/geometra",
  "keywords": [
    "textura",
    "server",
    "websocket",
    "layout",
    "dom-free"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@geometra/core": "^1.6.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13"
  }
}
