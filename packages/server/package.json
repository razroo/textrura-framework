{
  "name": "@textura/server",
  "version": "0.1.0",
  "description": "Server-side layout engine with WebSocket geometry streaming",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/razroo/textrura-framework",
    "directory": "packages/server"
  },
  "homepage": "https://razroo.github.io/textrura-framework",
  "keywords": ["textura", "server", "websocket", "layout", "dom-free"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@textura/core": "^0.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13"
  }
}
