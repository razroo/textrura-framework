{
  "name": "@geometra/client",
  "version": "0.3.1",
  "description": "Thin client that receives server-computed geometry and paints via renderer",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/razroo/geometra",
    "directory": "packages/client"
  },
  "homepage": "https://razroo.github.io/geometra",
  "keywords": [
    "textura",
    "client",
    "websocket",
    "thin-client",
    "dom-free"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@geometra/core": "file:../core"
  }
}
