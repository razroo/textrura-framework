{
  "name": "@textura/renderer-terminal",
  "version": "0.1.0",
  "description": "Terminal/TUI renderer for Textura framework",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@textura/core": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  }
}
