{
  "name": "@geometra/demo-auth-registry-server-client",
  "private": true,
  "type": "module",
  "scripts": {
    "server": "tsx server.ts",
    "client": "vite --config vite.config.ts",
    "start": "concurrently -k -n server,vite -c green,cyan \"tsx server.ts\" \"vite --config vite.config.ts\"",
    "dev": "npm run start",
    "build": "vite build --config vite.config.ts"
  },
  "dependencies": {
    "@geometra/auth": "^1.0.1",
    "@geometra/client": "*",
    "@geometra/core": "*",
    "@geometra/renderer-canvas": "*",
    "@geometra/server": "*",
    "@geometra/token-registry": "^0.1.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "vite": "^8.0.3"
  }
}
